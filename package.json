{
  "name": "trundler-app",
  "version": "0.1.11",
  "description": "Local grocery-shopping companion: a chat agent (Ollama or Claude) driving the trundler-mcp data layer, wrapped in an Electron desktop app.",
  "author": "Michael Wells <mike@aaic.nz>",
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "smoke": "node scripts/smoke.mjs",
    "libcheck": "node scripts/lib-check.mjs",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@auckland-ai-collective/trundler-mcp": "^0.1.6",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "dompurify": "^3.1.7",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "marked": "^14.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.sygnal.trundler",
    "productName": "Trundler",
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.icns"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
