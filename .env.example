# Trundler app configuration (all optional — the UI can set these too).
# Copy to .env for local dev overrides.

# Which brain to use by default: ollama | anthropic
TRUNDLER_BACKEND=ollama

# --- Ollama (local, default for dev) ---
OLLAMA_HOST=http://localhost:11434
TRUNDLER_OLLAMA_MODEL=llama3.1:8b

# --- Claude (cloud, optional) ---
ANTHROPIC_API_KEY=
TRUNDLER_ANTHROPIC_MODEL=claude-sonnet-4-6

# Path to the built trundler-mcp server entry
TRUNDLER_MCP_PATH=D:/Projects/MCP/trundler-mcp/dist/index.js

# Default grocery provider: countdown | newworld | paknsave
TRUNDLER_PROVIDER=countdown
